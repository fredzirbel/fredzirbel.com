---
/**
 * Site-wide ambient background: three huge blurred color blobs drifting
 * slowly behind all content. Transform/opacity only; frozen to a static
 * glow under reduced motion via the global CSS gate.
 */
---

<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
  <div
    class="orb animate-float-a left-[-10%] top-[-15%] h-[55vmax] w-[55vmax] opacity-30"
    style="background: radial-gradient(circle, var(--color-accent), transparent 70%); animation-duration: 24s;"
  >
  </div>
  <div
    class="orb animate-float-b right-[-15%] top-[30%] h-[50vmax] w-[50vmax] opacity-25"
    style="background: radial-gradient(circle, var(--color-slate), transparent 70%); animation-duration: 30s;"
  >
  </div>
  <div
    class="orb animate-float-a bottom-[-20%] left-[20%] h-[45vmax] w-[45vmax] opacity-20"
    style="background: radial-gradient(circle, var(--color-accent-bright), transparent 70%); animation-duration: 36s; animation-delay: -18s;"
  >
  </div>
</div>

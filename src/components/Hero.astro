---
import Icon from './Icon.astro';
---

<section class="relative flex min-h-dvh flex-col justify-center overflow-hidden">
  <!-- Layered background: blueprint grid, glowing orbs, particle canvas -->
  <div class="grid-lines absolute inset-0 -z-20" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-20 overflow-hidden" aria-hidden="true">
    <div
      class="orb animate-float-a left-[8%] top-[12%] h-[45vmax] w-[45vmax] opacity-25"
      style="background: radial-gradient(circle, var(--color-accent), transparent 65%);"
    >
    </div>
    <div
      class="orb animate-float-b right-[5%] bottom-[8%] h-[38vmax] w-[38vmax] opacity-30"
      style="background: radial-gradient(circle, var(--color-slate), transparent 65%);"
    >
    </div>
  </div>
  <div id="hero-canvas" aria-hidden="true" class="absolute inset-0 -z-10"></div>

  <div class="mx-auto w-full max-w-5xl px-6 pt-24">
    <p
      data-hero-item
      class="mb-6 flex items-center gap-3 font-mono text-xs sm:text-sm uppercase tracking-widest text-accent-bright"
    >
      <span class="inline-block h-px w-10 bg-accent" aria-hidden="true"></span>
      Principal Security Analyst
    </p>
    <h1
      data-hero-item
      class="font-heading font-black tracking-[-0.04em] leading-[0.95] text-[clamp(3rem,10vw,8rem)] pb-2"
    >
      Fred Zirbel
    </h1>
    <p data-hero-item class="mt-8 max-w-xl text-base sm:text-lg text-muted-fg">
      Threat investigation, detection engineering, and SOC automation.
      I help defend 2,500+ environments at a 24/7 MDR, and build security
      tooling to understand how everything works underneath.
    </p>
    <div data-hero-item class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 rounded-md bg-foreground px-6 py-3 text-sm font-medium text-background shadow-[0_0_25px_rgb(98_146_158/0.25)] transition-[background-color,box-shadow] duration-(--duration-fast) hover:bg-accent-bright hover:shadow-[0_0_35px_rgb(98_146_158/0.45)]"
      >
        View projects
      </a>
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-md border border-line px-6 py-3 text-sm font-medium transition-colors duration-(--duration-fast) hover:border-accent hover:text-accent-bright"
      >
        Read the blog
      </a>
    </div>
  </div>

  <a
    href="#about"
    aria-label="Scroll to about section"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-muted-fg transition-colors duration-(--duration-fast) hover:text-accent-bright"
    data-hero-item
  >
    <Icon name="arrow-down" class="size-5 animate-bounce" />
  </a>

  <script>
    // Lazy-load the Three.js scene after first paint (desktop only).
    // Reduced-motion users get a static render of the same network;
    // localStorage 'force-motion' = '1' opts back into full animation.
    const forced = localStorage.getItem('force-motion') === '1';
    const wantsMotion =
      forced || !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const bigEnough = window.matchMedia('(min-width: 768px)').matches;
    if (bigEnough) {
      const start = () =>
        import('../scripts/particles').then((m) => m.initParticles({ animate: wantsMotion }));
      'requestIdleCallback' in window
        ? requestIdleCallback(start, { timeout: 2000 })
        : setTimeout(start, 300);
    }
  </script>
</section>

---
interface Props {
  /** When true, JS hides the nav until the user scrolls past the hero */
  delayed?: boolean;
}
const { delayed = false } = Astro.props;

const links = [
  { href: '/#about', label: 'About' },
  { href: '/#projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header
  id="site-nav"
  data-delayed={delayed ? 'true' : undefined}
  class="fixed top-0 inset-x-0 z-40 border-b border-transparent transition-[background-color,border-color,opacity,transform] duration-(--duration-base)"
>
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4"
    aria-label="Main"
  >
    <a
      href="/"
      class="font-heading text-sm font-bold tracking-tight hover:text-accent transition-colors duration-(--duration-fast)"
    >
      fred zirbel
    </a>
    <ul class="flex items-center gap-6 sm:gap-8">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath.startsWith('/blog') && link.href === '/blog' ? 'page' : undefined}
              class:list={[
                'text-sm transition-colors duration-(--duration-fast) hover:text-accent',
                currentPath.startsWith('/blog') && link.href === '/blog'
                  ? 'text-accent'
                  : 'text-muted-fg',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  /* Solid backdrop once scrolled (class added by motion script) */
  #site-nav.nav-scrolled {
    background-color: rgb(10 10 15 / 0.85);
    backdrop-filter: blur(12px);
    border-color: var(--color-line);
  }
  /* Hidden state before the hero is passed (only applied when JS + motion allowed) */
  #site-nav.nav-hidden {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
  }
</style>

---
interface Props {
  /** When true, JS hides the nav until the user scrolls past the hero */
  delayed?: boolean;
}
const { delayed = false } = Astro.props;

const links = [
  { href: '/#about', label: 'About' },
  { href: '/#projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header
  id="site-nav"
  data-delayed={delayed ? 'true' : undefined}
  class="fixed top-4 inset-x-0 z-40 flex justify-center px-6 transition-[opacity,transform] duration-(--duration-base)"
>
  <nav
    class="rounded-full border border-line bg-surface/75 px-2 py-1.5 backdrop-blur-md"
    aria-label="Main"
  >
    <ul class="flex items-center gap-1">
      {
        links.map((link) => {
          const active = currentPath.startsWith('/blog') && link.href === '/blog';
          return (
            <li>
              <a
                href={link.href}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'inline-block rounded-full px-4 py-1.5 text-sm transition-colors duration-(--duration-fast)',
                  active
                    ? 'bg-raised text-accent-bright'
                    : 'text-muted-fg hover:text-foreground hover:bg-raised/70',
                ]}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<style>
  /* Hidden state before the hero is passed (only applied when JS + motion allowed) */
  #site-nav.nav-hidden {
    opacity: 0;
    transform: translateY(-12px);
    pointer-events: none;
  }
</style>

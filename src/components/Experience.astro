---
import Section from './Section.astro';

/** Content sourced from Fred's resume (July 2026). */
const roles = [
  {
    title: 'Principal Security Analyst',
    period: 'Current',
    bullets: [
      'Investigate and respond to phishing, malware, and identity-based intrusion attempts (unauthorized access, impossible travel, password spray) across 2,500+ multi-tenant environments in a Managed Detection and Response operation',
      'Perform log and endpoint-telemetry analysis with custom KQL, correlating URL clicks, file downloads, identity activity, and process telemetry to establish root cause and reconstruct attacker actions',
      'Execute containment through EDR/XDR consoles: isolating compromised hosts, disabling affected accounts, and terminating active sessions to halt threats before escalation',
      'Produce evidence-backed escalations with full attribution, timeline, and remediation guidance, and brief stakeholders directly in 3 to 5 weekly high-priority incident calls',
      'Detect and correlate cross-tenant phishing and malware campaigns from shared indicators, escalating campaign-level findings to enable coordinated, multi-customer response',
      'Engineer SOC detection content and SOPs: 500+ suppression filters (KVP logic + regex), team-adopted escalation templates, and a daily quality gate validating suppression and orchestration changes before deployment',
    ],
  },
  {
    title: 'Security Analyst',
    period: 'Oct 2024 - Jul 2025',
    bullets: [
      'Triaged 300+ monthly security alerts across a large multi-tenant client base, investigating identity threats, phishing, malware, and endpoint activity',
      'Developed KQL investigation queries in Microsoft Sentinel and Defender to correlate URL clicks, file downloads, identity activity, and endpoint telemetry for root-cause analysis',
      'Produced client-ready escalations with accurate attribution and remediation guidance; recognized during onboarding for escalation accuracy and consistency',
    ],
  },
];

const platforms = [
  'Microsoft Defender XDR',
  'Microsoft Sentinel',
  'CrowdStrike Falcon',
  'Cortex XDR',
  'SentinelOne',
  'Splunk ES',
  'Sumo Logic',
  'MITRE ATT&CK',
  'NIST SP 800-61',
];
---

<Section id="experience" number="02" eyebrow="Experience" heading="Where I work">
  <div class="max-w-3xl">
    <div class="mb-10 flex flex-wrap items-baseline justify-between gap-2">
      <h3 class="font-heading text-2xl font-bold">
        Critical Start
        <span class="ml-2 font-mono text-xs font-normal text-accent-bright">24/7 MDR</span>
      </h3>
      <p class="font-mono text-xs text-muted-fg">Plano, TX</p>
    </div>

    <ol class="relative space-y-12 border-l border-line pl-8">
      {
        roles.map((role) => (
          <li class="relative">
            <span
              class="absolute -left-[37px] top-1.5 size-2.5 rounded-full border-2 border-accent bg-background"
              aria-hidden="true"
            />
            <div class="mb-4 flex flex-wrap items-baseline justify-between gap-2">
              <h4 class="font-heading text-lg font-bold">{role.title}</h4>
              <p class="font-mono text-xs text-accent-bright">{role.period}</p>
            </div>
            <ul class="space-y-3 text-sm text-muted-fg">
              {role.bullets.map((bullet) => (
                <li class="flex gap-3">
                  <span class="mt-2 size-1 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                  {bullet}
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>

    <div class="mt-12">
      <p class="mb-3 font-mono text-xs uppercase tracking-widest text-muted-fg">
        Daily platforms &amp; frameworks
      </p>
      <ul class="flex flex-wrap gap-2">
        {
          platforms.map((platform) => (
            <li class="rounded border border-line bg-surface/70 px-2.5 py-1 font-mono text-[11px] text-muted-fg">
              {platform}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Section>

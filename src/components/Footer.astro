---
import Icon from './Icon.astro';

const year = new Date().getFullYear();
---

<footer id="contact" class="relative overflow-hidden border-t border-line">
  <div
    class="orb left-1/2 top-full h-[40vmax] w-[60vmax] -translate-x-1/2 -translate-y-1/3 opacity-20"
    style="background: radial-gradient(circle, var(--color-accent), transparent 65%);"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-5xl px-6 py-24 sm:py-32">
    <p class="mb-4 flex items-center gap-3 font-mono text-xs uppercase tracking-widest">
      <span class="text-accent-bright">06</span>
      <span class="text-muted-fg">Contact</span>
      <span class="h-px max-w-24 flex-1 bg-line" aria-hidden="true"></span>
    </p>
    <a
      href="mailto:fredzirbel@pm.me"
      class="group inline-block font-heading text-[clamp(2.5rem,7vw,5.5rem)] font-black leading-none tracking-tight"
    >
      <span
        class="text-gradient animate-gradient-pan transition-opacity duration-(--duration-base) group-hover:opacity-80"
      >
        Let's talk<span aria-hidden="true">&nbsp;&rarr;</span>
      </span>
    </a>
    <p class="mt-8 max-w-xl text-muted-fg">
      Open to conversations about detection engineering, SOC operations, or
      anything security. Email is fastest; LinkedIn works too.
    </p>
    <ul class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4">
      <li>
        <a
          href="mailto:fredzirbel@pm.me"
          class="group inline-flex items-center gap-2 text-sm transition-colors duration-(--duration-fast) hover:text-accent-bright"
        >
          <Icon name="mail" class="size-4 text-muted-fg transition-colors duration-(--duration-fast) group-hover:text-accent-bright" />
          fredzirbel@pm.me
        </a>
      </li>
      <li>
        <a
          href="https://github.com/fredzirbel"
          rel="noopener"
          class="group inline-flex items-center gap-2 text-sm transition-colors duration-(--duration-fast) hover:text-accent-bright"
        >
          <Icon name="github" class="size-4 text-muted-fg transition-colors duration-(--duration-fast) group-hover:text-accent-bright" />
          GitHub
        </a>
      </li>
      <li>
        <a
          href="https://linkedin.com/in/fredzirbel"
          rel="noopener"
          class="group inline-flex items-center gap-2 text-sm transition-colors duration-(--duration-fast) hover:text-accent-bright"
        >
          <Icon name="linkedin" class="size-4 text-muted-fg transition-colors duration-(--duration-fast) group-hover:text-accent-bright" />
          LinkedIn
        </a>
      </li>
      <li>
        <a
          href="/rss.xml"
          class="group inline-flex items-center gap-2 text-sm transition-colors duration-(--duration-fast) hover:text-accent-bright"
        >
          <Icon name="rss" class="size-4 text-muted-fg transition-colors duration-(--duration-fast) group-hover:text-accent-bright" />
          RSS
        </a>
      </li>
    </ul>
    <p class="mt-16 font-mono text-xs text-muted-fg">
      © {year} Fred Zirbel. Built with Astro, deployed on Cloudflare Pages.
    </p>
  </div>
</footer>

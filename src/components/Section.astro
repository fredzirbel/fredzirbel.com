---
/** Shared section shell: numbered eyebrow + rule line + oversized heading */
interface Props {
  id: string;
  number: string;
  eyebrow: string;
  heading: string;
}
const { id, number, eyebrow, heading } = Astro.props;
---

<section id={id} class="scroll-mt-20 border-t border-line">
  <div class="mx-auto max-w-5xl px-6 py-24 sm:py-32" data-reveal>
    <p class="mb-4 flex items-center gap-3 font-mono text-xs uppercase tracking-widest">
      <span class="text-accent-bright">{number}</span>
      <span class="text-muted-fg">{eyebrow}</span>
      <span class="h-px flex-1 max-w-24 bg-line" aria-hidden="true"></span>
    </p>
    <h2 class="mb-12 font-heading text-3xl sm:text-5xl font-bold tracking-tight">
      {heading}<span class="text-accent">.</span>
    </h2>
    <slot />
  </div>
</section>

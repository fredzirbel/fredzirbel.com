---
import { getCollection } from 'astro:content';
import Section from './Section.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<Section id="writing" number="05" eyebrow="Writing" heading="Latest from the blog">
  <div class="space-y-1" data-reveal-stagger>
    {
      posts.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="group flex flex-col gap-1 rounded-lg px-4 py-5 -mx-4 transition-colors duration-(--duration-fast) hover:bg-surface sm:flex-row sm:items-baseline sm:justify-between sm:gap-6"
        >
          <div class="min-w-0">
            <h3 class="font-heading font-bold group-hover:text-accent transition-colors duration-(--duration-fast)">
              {post.data.title}
            </h3>
            <p class="mt-1 text-sm text-muted-fg line-clamp-2">{post.data.description}</p>
          </div>
          <time
            datetime={post.data.date.toISOString()}
            class="shrink-0 font-mono text-xs text-muted-fg"
          >
            {formatDate(post.data.date)}
          </time>
        </a>
      ))
    }
  </div>
  <a
    href="/blog"
    class="mt-8 inline-block text-sm text-accent underline decoration-accent/40 underline-offset-4 transition-colors duration-(--duration-fast) hover:decoration-accent"
  >
    All posts
  </a>
</Section>

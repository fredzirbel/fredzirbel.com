---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<Layout
  title="Blog - Fred Zirbel"
  description="Notes on detection engineering, SOC operations, and security tooling - documenting what I'm learning as I build."
>
  <div class="mx-auto max-w-5xl px-6 pt-36 pb-24 sm:pb-32" data-reveal>
    <p class="font-mono text-xs uppercase tracking-widest text-accent mb-4">Blog</p>
    <h1 class="font-heading text-4xl sm:text-6xl font-bold tracking-tight mb-6">
      Writing
    </h1>
    <p class="max-w-xl text-muted-fg mb-16">
      Notes on detection engineering, SOC operations, and the security tooling
      I'm building. Learning in public.
    </p>

    <div class="space-y-1">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group flex flex-col gap-1 rounded-lg px-4 py-6 -mx-4 transition-colors duration-(--duration-fast) hover:bg-surface sm:flex-row sm:items-baseline sm:justify-between sm:gap-6 border-b border-line last:border-b-0"
          >
            <div class="min-w-0">
              <h2 class="font-heading text-lg font-bold group-hover:text-accent transition-colors duration-(--duration-fast)">
                {post.data.title}
              </h2>
              <p class="mt-2 text-sm text-muted-fg">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <ul class="mt-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <li class="rounded border border-line px-2 py-0.5 font-mono text-[11px] text-muted-fg">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </div>
            <time
              datetime={post.data.date.toISOString()}
              class="shrink-0 font-mono text-xs text-muted-fg"
            >
              {formatDate(post.data.date)}
            </time>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
